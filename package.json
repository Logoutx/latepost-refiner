{
  "name": "latepost-refiner",
  "version": "1.0.0",
  "description": "访谈转录精校流水线：侦察、联网核实、统一校对表、并行精校加完整性核对，可选产出逻辑顺序稿、访谈总结、时间线。Claude Code Workflow 版和独立命令行版共用一套 core/。",
  "type": "module",
  "bin": {
    "latepost-refiner": "universal/cli.js",
    "latepost-refiner-web": "universal/server.js",
    "transcriber": "universal/cli.js",
    "transcriber-web": "universal/server.js"
  },
  "files": [
    ".env.example",
    "README.md",
    "build/",
    "claude-code-skill/",
    "codex-skills/",
    "core/",
    "docs/",
    "engines/",
    "eval/",
    "scripts/",
    "universal/"
  ],
  "exports": {
    "./core": "./core/pipeline.js",
    "./engine": "./engines/api.js"
  },
  "scripts": {
    "pretest": "node build/sync-skills.mjs --check",
    "test": "node --test",
    "sync:skills": "node build/sync-skills.mjs",
    "latepost-refiner": "node universal/cli.js",
    "web": "node universal/server.js",
    "build:cc": "node build/build-cc.mjs",
    "build:embed": "node build/embed-assets.mjs",
    "build:binary": "bash build/build-binary.sh",
    "eval": "node eval/run.mjs",
    "eval:filler": "node eval/run.mjs",
    "eval:golden": "node eval/golden-run.mjs",
    "eval:produce": "node eval/produce.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "mammoth": "^1.12.0",
    "openai": "^6.44.0",
    "p-limit": "^7.3.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
