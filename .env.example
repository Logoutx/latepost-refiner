# Copy to .env (or export in your shell). The Universal CLI reads the key for the
# --provider you pick (default: anthropic).
ANTHROPIC_API_KEY=sk-ant-...      # --provider anthropic (default; native server-side web search)
DEEPSEEK_API_KEY=sk-...           # --provider deepseek
ZHIPUAI_API_KEY=...               # --provider glm  (or ZAI_API_KEY for the z.ai international endpoint)
MOONSHOT_API_KEY=sk-...           # --provider kimi
OPENAI_API_KEY=sk-...             # --provider openai

# Optional: web search backend for the OpenAI-compatible providers (deepseek/glm/kimi/openai).
# Without it, verify/timeline degrade gracefully (refine 精校 never goes online, so it's unaffected).
# The anthropic provider has built-in server-side search and does NOT need this.
TAVILY_API_KEY=tvly-...
