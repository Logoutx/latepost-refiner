# Copy to .env (or export in your shell). The Universal CLI runs on DeepSeek only.
DEEPSEEK_API_KEY=sk-...           # required — DeepSeek 的 API key，精校全程使用

# Optional: Tavily web-search backend for 联网核实 / 时间线. Without it, verify/timeline
# degrade gracefully to no-verify (refine 精校 never goes online, so it's unaffected).
TAVILY_API_KEY=tvly-...
